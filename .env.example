# AmanTech Smart AI – Environment Variables
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git

# Back4App (Parse) Configuration
# Get from: https://dashboard.back4app.com → Your App → App Settings → Security & Keys
REACT_APP_BACK4APP_APP_ID=your_back4app_application_id_here
REACT_APP_BACK4APP_JS_KEY=your_back4app_javascript_key_here

# Google Gemini API (FREE)
# Get from: https://aistudio.google.com/app/apikey
# Sign in with Google → "Create API Key" → copy it below
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# Paystack Payment Gateway
# Get from: https://dashboard.paystack.com/#/settings/developer
# Use test key (pk_test_...) for testing, live key (pk_live_...) for production
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
